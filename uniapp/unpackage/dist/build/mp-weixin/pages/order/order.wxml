<view class="order-container data-v-26733ccb"><view class="page-header data-v-26733ccb"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="header-left data-v-26733ccb" bindtap="__e"><u-icon vue-id="3c50aaa2-1" name="arrow-left" size="20" class="data-v-26733ccb" bind:__l="__l"></u-icon></view><view class="header-title data-v-26733ccb">我的订单</view><view class="header-right data-v-26733ccb"></view></view><view class="order-tabs data-v-26733ccb"><block wx:for="{{tabs}}" wx:for-item="tab" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['switchTab',[index]]]]]}}" class="{{['tab-item','data-v-26733ccb',(activeTab===index)?'active':'']}}" bindtap="__e">{{''+tab.name+''}}<block wx:if="{{tab.count>0}}"><view class="tab-badge data-v-26733ccb">{{tab.count}}</view></block></view></block></view><view class="order-list data-v-26733ccb"><block wx:for="{{orderList}}" wx:for-item="order" wx:for-index="index" wx:key="id"><view class="order-item data-v-26733ccb"><view class="order-header data-v-26733ccb"><view class="order-info data-v-26733ccb"><view class="order-id data-v-26733ccb">{{"订单号："+order.orderId}}</view><view class="{{['order-status','data-v-26733ccb',order.statusClass]}}">{{order.statusText}}</view></view><view class="order-platform data-v-26733ccb"><image src="{{order.platformIcon}}" mode="aspectFit" class="data-v-26733ccb"></image><text class="data-v-26733ccb">{{order.platformName}}</text></view></view><view data-event-opts="{{[['tap',[['goToOrderDetail',['$0'],[[['orderList','id',order.id]]]]]]]}}" class="order-content data-v-26733ccb" bindtap="__e"><view class="order-preview data-v-26733ccb"><image src="{{order.taskImage}}" mode="aspectFill" class="data-v-26733ccb"></image><view class="order-details data-v-26733ccb"><view class="task-title data-v-26733ccb">{{order.taskTitle}}</view><view class="task-desc data-v-26733ccb">{{order.taskDesc}}</view></view></view><view class="order-summary data-v-26733ccb"><view class="summary-row data-v-26733ccb"><text class="label data-v-26733ccb">助力次数:</text><text class="value data-v-26733ccb">{{order.assistCount+"次"}}</text></view><view class="summary-row data-v-26733ccb"><text class="label data-v-26733ccb">单价:</text><text class="value data-v-26733ccb">{{"¥"+order.unitPrice}}</text></view><view class="summary-row total data-v-26733ccb"><text class="label data-v-26733ccb">总计:</text><text class="value total-price data-v-26733ccb">{{"¥"+order.totalPrice}}</text></view></view></view><view class="order-footer data-v-26733ccb"><view class="order-date data-v-26733ccb">{{order.createTime}}</view><view class="order-actions data-v-26733ccb"><block wx:if="{{order.status==='pending_payment'}}"><button data-event-opts="{{[['tap',[['payOrder',['$0'],[[['orderList','id',order.id]]]]]]]}}" class="action-btn data-v-26733ccb" bindtap="__e">付款</button></block><block wx:if="{{order.status==='in_progress'}}"><button data-event-opts="{{[['tap',[['viewProgress',['$0'],[[['orderList','id',order.id]]]]]]]}}" class="action-btn data-v-26733ccb" bindtap="__e">查看进度</button></block><block wx:if="{{order.status==='completed'}}"><button data-event-opts="{{[['tap',[['viewResult',['$0'],[[['orderList','id',order.id]]]]]]]}}" class="action-btn data-v-26733ccb" bindtap="__e">查看结果</button></block><button data-event-opts="{{[['tap',[['contactSeller',['$0'],[[['orderList','id',order.id]]]]]]]}}" class="action-btn primary data-v-26733ccb" bindtap="__e">联系客服</button></view></view></view></block></view><block wx:if="{{$root.g0===0}}"><view class="empty-state data-v-26733ccb"><u-empty vue-id="3c50aaa2-2" mode="order" icon="/static/images/order_empty.png" class="data-v-26733ccb" bind:__l="__l" vue-slots="{{['default']}}"><view class="empty-text data-v-26733ccb">{{"暂无"+tabs[activeTab].name+"订单"}}</view><button data-event-opts="{{[['tap',[['goToBoostSquare',['$event']]]]]}}" class="empty-btn data-v-26733ccb" bindtap="__e">去助力广场</button></u-empty></view></block></view>