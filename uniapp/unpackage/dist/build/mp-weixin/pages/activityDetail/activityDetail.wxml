<view class="page data-v-f18ab57c"><scroll-view class="scroll data-v-f18ab57c" scroll-y="{{true}}"><view class="header data-v-f18ab57c"><image class="banner data-v-f18ab57c" src="/static/index/icon1.png" mode="aspectFill"></image><view class="title data-v-f18ab57c">{{''+(activity.title||'活动标题示例')+''}}</view><view class="sub-title data-v-f18ab57c">{{''+(activity.subTitle||'助力活动说明文案示例')+''}}</view></view><view class="section data-v-f18ab57c"><view class="section-title data-v-f18ab57c">重要说明</view><view class="section-body data-v-f18ab57c"><block wx:for="{{importantTips}}" wx:for-item="tip" wx:for-index="index" wx:key="index"><view class="bullet data-v-f18ab57c">{{''+(index+1)+". "+tip+''}}</view></block></view></view><view class="section data-v-f18ab57c"><view class="section-title data-v-f18ab57c">活动入口</view><view class="section-body data-v-f18ab57c"><block wx:for="{{entranceSteps}}" wx:for-item="text" wx:for-index="index" wx:key="index"><view class="paragraph data-v-f18ab57c">{{''+text+''}}</view></block></view></view><view class="section data-v-f18ab57c"><view class="section-title data-v-f18ab57c">自测流程</view><view class="section-body data-v-f18ab57c"><block wx:for="{{selfTestSteps}}" wx:for-item="text" wx:for-index="index" wx:key="index"><view class="paragraph data-v-f18ab57c">{{''+text+''}}</view></block></view></view><view class="section data-v-f18ab57c"><view class="section-title data-v-f18ab57c">下单流程</view><view class="section-body data-v-f18ab57c"><block wx:for="{{orderSteps}}" wx:for-item="text" wx:for-index="index" wx:key="index"><view class="paragraph data-v-f18ab57c">{{''+text+''}}</view></block></view></view><view class="section data-v-f18ab57c"><view class="section-title data-v-f18ab57c">查看进度</view><view class="section-body data-v-f18ab57c"><block wx:for="{{progressSteps}}" wx:for-item="text" wx:for-index="index" wx:key="index"><view class="paragraph data-v-f18ab57c">{{''+text+''}}</view></block></view></view><view class="section data-v-f18ab57c"><view class="section-title data-v-f18ab57c">领取赏金</view><view class="section-body data-v-f18ab57c"><block wx:for="{{rewardSteps}}" wx:for-item="text" wx:for-index="index" wx:key="index"><view class="paragraph data-v-f18ab57c">{{''+text+''}}</view></block></view></view><view class="section data-v-f18ab57c"><view class="section-title data-v-f18ab57c">售后流程</view><view class="section-body data-v-f18ab57c"><block wx:for="{{afterSaleSteps}}" wx:for-item="text" wx:for-index="index" wx:key="index"><view class="paragraph data-v-f18ab57c">{{''+text+''}}</view></block></view></view></scroll-view><view class="footer data-v-f18ab57c"><view data-event-opts="{{[['tap',[['toggleAgree',['$event']]]]]}}" class="agree-row data-v-f18ab57c" bindtap="__e"><radio style="transform:scale(0.8);" checked="{{agreed}}" color="#FF7A00" class="data-v-f18ab57c"></radio><text class="agree-text data-v-f18ab57c"> 我已仔细阅读并了解活动规则，下单即视为确认接受所有条款 </text></view><view data-event-opts="{{[['tap',[['handleSubmit',['$event']]]]]}}" class="{{['submit-btn','data-v-f18ab57c',(!agreed)?'disabled':'']}}" bindtap="__e"> 立即下单 </view></view></view>